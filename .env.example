# ── Orchestrator secrets ──────────────────────────────────────────
# Groq free-tier key → https://console.groq.com/keys
GROQ_API_KEY=

# Brave Search API (free tier: 2000 queries/mo) → https://api.search.brave.com/
BRAVE_API_KEY=

# Pexels API (free, unlimited for dev) → https://www.pexels.com/api/
PEXELS_API_KEY=

# Reddit API (free) — create a "script" app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# GitHub — a fine-grained PAT with Contents: Read/Write on the blog repo
GITHUB_TOKEN=
GITHUB_OWNER=your-gh-username
GITHUB_REPO=trendblog
GITHUB_BRANCH=main

# Secret the cron invoker must send as `Authorization: Bearer …`
CRON_SECRET=61a071c638abfcf6d97ab2d620d92f3e36c30fa79f529bad0ed0eedf5da93f46

# ── Optional ──────────────────────────────────────────────────────
# Your deployed URL (used for sitemap, RSS feed, OG tags)
NEXT_PUBLIC_SITE_URL=https://your-site.pages.dev
# Comma-separated YouTube channel IDs to pull transcripts from
YOUTUBE_CHANNELS=
# Comma-separated extra RSS feeds
EXTRA_FEEDS=

# ── TinaCMS (only if you enable the hosted editor) ────────────────
# Leave these blank for self-hosted mode (local filesystem editing)
# The build script will automatically set placeholder values if needed
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
